{
  "manifest_version": 3,
  "name": "YouTube Skip Control",
  "version": "1.0.0",
  "description": "Customize Left and Right Arrow skip times on YouTube.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Skip Control",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}